# Example creation_rules for a multi-operator setup. Copy to
# ~/.config/vpn-provision/.sops.yaml (NOT into this repo) and edit to
# match your operator set + scope split.
#
# SOPS reads creation_rules top-to-bottom and applies the first rule
# whose path_regex matches. Order matters — the most specific path
# regex comes first.
#
# Recipient lists are comma-separated age recipients. Each operator's
# age public key (or YubiKey-backed age1yubikey…) appears in EVERY
# group they are allowed to decrypt.

creation_rules:
  # Prod secrets — full fleet operators only.
  - path_regex: '^prod\.secrets\.sops\.yaml$'
    age: >-
      age1FULL_PROD_OPERATOR_1,
      age1FULL_PROD_OPERATOR_2

  # Staging secrets — wider audience (devs running CI tests).
  - path_regex: '^staging\.secrets\.sops\.yaml$'
    age: >-
      age1FULL_PROD_OPERATOR_1,
      age1FULL_PROD_OPERATOR_2,
      age1STAGING_DEV_1,
      age1STAGING_DEV_2

  # Subscription-only delivery-host secrets — split so the operator
  # who runs subscription delivery doesn't see the REALITY private key
  # for the transport host. Combine with the inventory split in
  # docs/MULTI-OPERATOR.md and the role-scoping in site.yml.
  - path_regex: '^subscription\.secrets\.sops\.yaml$'
    age: >-
      age1FULL_PROD_OPERATOR_1,
      age1SUBSCRIPTION_OPERATOR

  # Audit log — full-fleet operators only (auditors typically aren't
  # operators; they get a separate read path via export + redaction).
  - path_regex: '^audit\.log\.age$'
    age: >-
      age1FULL_PROD_OPERATOR_1,
      age1FULL_PROD_OPERATOR_2

  # Catch-all so SOPS refuses to encrypt anything you didn't anticipate.
  - path_regex: '.*'
    age: 'age1FULL_PROD_OPERATOR_1'