{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vpn-deploy/secrets.schema.json",
  "title": "vpn-deploy secrets schema",
  "description": "Formal contract for secrets/prod.secrets.example.yaml and any operator-side decrypted SOPS file. The Ansible roles consume these keys at deploy time; a missing or malformed entry surfaces today as a render-time error on the VPS. Catching it at PR time is the point of this file. The placeholder string REPLACE_WITH_* validates structurally; --strict mode at the validator rejects it for real deploys.",
  "type": "object",
  "required": [
    "xray",
    "nginx_xhttp",
    "hysteria",
    "amneziawg_secrets",
    "backup",
    "watchdog_secrets"
  ],
  "additionalProperties": true,
  "$defs": {
    "sha256_hex": {
      "type": "string",
      "pattern": "^([0-9a-fA-F]{64}|REPLACE_WITH_[A-Z0-9_]+|0{64})$"
    },
    "version_tag": {
      "type": "string",
      "pattern": "^(v[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.+-]+)?|REPLACE_WITH_[A-Z0-9_]+)$"
    },
    "uuid_or_placeholder": {
      "type": "string",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}|REPLACE_WITH_[A-Z0-9_]+)$"
    },
    "short_id_or_placeholder": {
      "type": "string",
      "pattern": "^([0-9a-fA-F]{2,16}|REPLACE_WITH_[A-Z0-9_]+)$"
    },
    "uint32_or_placeholder": {
      "oneOf": [
        { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        { "type": "string", "pattern": "^(REPLACE_WITH_[A-Z0-9_]+|[0-9]+)$" }
      ]
    },
    "pem_block": {
      "type": "string",
      "minLength": 30
    },
    "ipv4_cidr": {
      "type": "string",
      "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}(/[0-9]{1,2})?$"
    }
  },
  "properties": {
    "xray": {
      "type": "object",
      "required": [
        "version",
        "linux_amd64_sha256",
        "linux_arm64_sha256",
        "reality_private_key",
        "reality_public_key",
        "target",
        "server_names",
        "xhttp_path",
        "clients"
      ],
      "properties": {
        "version": { "$ref": "#/$defs/version_tag" },
        "linux_amd64_sha256": { "$ref": "#/$defs/sha256_hex" },
        "linux_arm64_sha256": { "$ref": "#/$defs/sha256_hex" },
        "reality_private_key": { "type": "string", "minLength": 16 },
        "reality_public_key": { "type": "string", "minLength": 16 },
        "target": {
          "type": "string",
          "pattern": "^([A-Za-z0-9.-]+|REPLACE_WITH_[A-Z0-9_]+):[0-9]+$"
        },
        "server_names": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "xhttp_path": { "type": "string", "pattern": "^/" },
        "clients": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "uuid", "short_id"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "uuid": { "$ref": "#/$defs/uuid_or_placeholder" },
              "short_id": { "$ref": "#/$defs/short_id_or_placeholder" }
            },
            "additionalProperties": false
          }
        },
        "cohorts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "port", "flow_mode"],
            "properties": {
              "name": { "type": "string" },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "flow_mode": { "enum": ["vision", "mux"] },
              "finalmask": { "type": "boolean" },
              "clients": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "nginx_xhttp": {
      "type": "object",
      "required": ["server_name", "cert_pem", "key_pem"],
      "properties": {
        "server_name": { "type": "string", "minLength": 1 },
        "cert_pem": { "$ref": "#/$defs/pem_block" },
        "key_pem": { "$ref": "#/$defs/pem_block" }
      },
      "additionalProperties": true
    },
    "hysteria": {
      "type": "object",
      "required": [
        "version",
        "linux_amd64_sha256",
        "linux_arm64_sha256",
        "cert_pem",
        "key_pem",
        "bandwidth_up",
        "bandwidth_down",
        "clients"
      ],
      "properties": {
        "version": { "$ref": "#/$defs/version_tag" },
        "linux_amd64_sha256": { "$ref": "#/$defs/sha256_hex" },
        "linux_arm64_sha256": { "$ref": "#/$defs/sha256_hex" },
        "cert_pem": { "$ref": "#/$defs/pem_block" },
        "key_pem": { "$ref": "#/$defs/pem_block" },
        "bandwidth_up": {
          "type": "string",
          "pattern": "^[0-9]+\\s*(bps|kbps|mbps|gbps)$"
        },
        "bandwidth_down": {
          "type": "string",
          "pattern": "^[0-9]+\\s*(bps|kbps|mbps|gbps)$"
        },
        "salamander_enabled": { "type": "boolean" },
        "salamander_password": { "type": "string" },
        "clients": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "password"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "password": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "naive_secrets": {
      "type": "object",
      "properties": {
        "server_name": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "probe_resistance_secret": { "type": "string" },
        "cert_pem": { "$ref": "#/$defs/pem_block" },
        "key_pem": { "$ref": "#/$defs/pem_block" }
      },
      "additionalProperties": true
    },
    "geodata": {
      "type": "object",
      "properties": {
        "geosite_url": { "type": "string" },
        "geoip_url": { "type": "string" },
        "geosite_sha256": { "$ref": "#/$defs/sha256_hex" },
        "geoip_sha256": { "$ref": "#/$defs/sha256_hex" },
        "install_dir": { "type": "string", "pattern": "^/" },
        "refresh_interval": {
          "type": "string",
          "pattern": "^[0-9]+(m|h|d)$"
        }
      },
      "additionalProperties": true
    },
    "amneziawg_go_version": { "type": "string", "minLength": 1 },
    "amneziawg_tools_version": { "type": "string", "minLength": 1 },
    "amneziawg_secrets": {
      "type": "object",
      "required": [
        "server_private_key",
        "jc",
        "jmin",
        "jmax",
        "s1",
        "s2",
        "h1",
        "h2",
        "h3",
        "h4",
        "peers"
      ],
      "properties": {
        "server_private_key": { "type": "string", "minLength": 16 },
        "jc": { "type": "integer", "minimum": 0, "maximum": 128 },
        "jmin": { "type": "integer", "minimum": 0, "maximum": 1280 },
        "jmax": { "type": "integer", "minimum": 0, "maximum": 1280 },
        "s1": { "type": "integer", "minimum": 0, "maximum": 1280 },
        "s2": { "type": "integer", "minimum": 0, "maximum": 1280 },
        "h1": { "$ref": "#/$defs/uint32_or_placeholder" },
        "h2": { "$ref": "#/$defs/uint32_or_placeholder" },
        "h3": { "$ref": "#/$defs/uint32_or_placeholder" },
        "h4": { "$ref": "#/$defs/uint32_or_placeholder" },
        "peers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "public_key", "preshared_key", "allowed_ips"],
            "properties": {
              "name": { "type": "string" },
              "public_key": { "type": "string", "minLength": 16 },
              "preshared_key": { "type": "string", "minLength": 16 },
              "allowed_ips": { "$ref": "#/$defs/ipv4_cidr" }
            }
          }
        },
        "instances": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "listen_port"],
            "properties": {
              "name": { "type": "string" },
              "listen_port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "backup": {
      "type": "object",
      "required": ["restic_password"],
      "properties": {
        "restic_password": { "type": "string", "minLength": 16 },
        "remote": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "rclone_remote": { "type": "string" },
            "rclone_path": { "type": "string" },
            "transfers": { "type": "integer", "minimum": 1, "maximum": 64 },
            "bwlimit": { "type": "string" },
            "rclone_config": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "watchdog_secrets": {
      "type": "object",
      "required": ["ntfy_topic"],
      "properties": {
        "ntfy_topic": { "type": "string", "minLength": 8 },
        "ntfy_token": { "type": "string" },
        "pushover_token": { "type": "string" },
        "pushover_user": { "type": "string" }
      },
      "additionalProperties": true
    },
    "subscription": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "server_name": { "type": "string" },
        "rate_limit": { "type": "string", "pattern": "^[0-9]+r/(s|m|h)$" },
        "rate_burst": { "type": "integer", "minimum": 0 },
        "subscription_dir": { "type": "string", "pattern": "^/" },
        "bootstrap_listen_addr": { "type": "string" },
        "bootstrap_listen_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "reads_log": { "type": "string", "pattern": "^/" },
        "revoked_file": { "type": "string", "pattern": "^/" },
        "revoked_tokens": { "type": "array", "items": { "type": "string" } },
        "revoked_token_hashes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  }
}
