#compdef vpnd

autoload -U is-at-least

_vpnd() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-e+[Target environment]:ENV:_default' \
'--env=[Target environment]:ENV:_default' \
'-p+[Cloud provider Terraform root]:PROVIDER:_default' \
'--provider=[Cloud provider Terraform root]:PROVIDER:_default' \
'--root=[Override the vpn-deploy repo root (default\: discover from cwd)]:ROOT:_files' \
'--explain[Print the underlying shell invocations and exit without running them]' \
'-y[Skip interactive confirmation prompts]' \
'--yes[Skip interactive confirmation prompts]' \
'--json[Emit machine-readable JSON instead of human output (where supported)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_vpnd_commands" \
"*::: :->vpnd" \
&& ret=0
    case $state in
    (vpnd)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vpnd-command-$line[1]:"
        case $line[1] in
            (deploy)
_arguments "${_arguments_options[@]}" : \
'-e+[Target environment]:ENV:_default' \
'--env=[Target environment]:ENV:_default' \
'-p+[Cloud provider Terraform root]:PROVIDER:_default' \
'--provider=[Cloud provider Terraform root]:PROVIDER:_default' \
'--root=[Override the vpn-deploy repo root (default\: discover from cwd)]:ROOT:_files' \
'--skip-precheck[Skip running pre-deploy guards (mirrors \`SKIP_PRECHECK=1\`)]' \
'--tag-on-success[Tag a known-good commit after a successful verify run]' \
'--explain[Print the underlying shell invocations and exit without running them]' \
'-y[Skip interactive confirmation prompts]' \
'--yes[Skip interactive confirmation prompts]' \
'--json[Emit machine-readable JSON instead of human output (where supported)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(reconverge)
_arguments "${_arguments_options[@]}" : \
'--host=[Limit to a single host from the registry]:HOST:_default' \
'-e+[Target environment]:ENV:_default' \
'--env=[Target environment]:ENV:_default' \
'-p+[Cloud provider Terraform root]:PROVIDER:_default' \
'--provider=[Cloud provider Terraform root]:PROVIDER:_default' \
'--root=[Override the vpn-deploy repo root (default\: discover from cwd)]:ROOT:_files' \
'--dry-run[Stop after dry-run; do not apply]' \
'--explain[Print the underlying shell invocations and exit without running them]' \
'-y[Skip interactive confirmation prompts]' \
'--yes[Skip interactive confirmation prompts]' \
'--json[Emit machine-readable JSON instead of human output (where supported)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(share)
_arguments "${_arguments_options[@]}" : \
'--type=[QR payload type]:TYPE:(singbox uri)' \
'--out=[Output directory for generated artifacts (default\: ./share/<client>/)]:OUT:_files' \
'-e+[Target environment]:ENV:_default' \
'--env=[Target environment]:ENV:_default' \
'-p+[Cloud provider Terraform root]:PROVIDER:_default' \
'--provider=[Cloud provider Terraform root]:PROVIDER:_default' \
'--root=[Override the vpn-deploy repo root (default\: discover from cwd)]:ROOT:_files' \
'--qr[Also emit a QR code image]' \
'--explain[Print the underlying shell invocations and exit without running them]' \
'-y[Skip interactive confirmation prompts]' \
'--yes[Skip interactive confirmation prompts]' \
'--json[Emit machine-readable JSON instead of human output (where supported)]' \
'-h[Print help]' \
'--help[Print help]' \
':client -- Client name:_default' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'--host=[Host alias from the registry; omitted = active env'\''s primary host]:HOST:_default' \
'--bundle=[Pack a diagnostic gzip-tar bundle at this path (orthogonal to --ai)]:BUNDLE:_files' \
'-e+[Target environment]:ENV:_default' \
'--env=[Target environment]:ENV:_default' \
'-p+[Cloud provider Terraform root]:PROVIDER:_default' \
'--provider=[Cloud provider Terraform root]:PROVIDER:_default' \
'--root=[Override the vpn-deploy repo root (default\: discover from cwd)]:ROOT:_files' \
'--ai[Format output as a clipboard-ready prompt for an AI assistant]' \
'--clip[Copy AI prompt to the system clipboard (requires --ai)]' \
'--explain[Print the underlying shell invocations and exit without running them]' \
'-y[Skip interactive confirmation prompts]' \
'--yes[Skip interactive confirmation prompts]' \
'--json[Emit machine-readable JSON instead of human output (where supported)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(probe)
_arguments "${_arguments_options[@]}" : \
'--host=[Host alias from the registry; omitted = active env'\''s primary host]:HOST:_default' \
'--profile=[Which profile to probe]:PROFILE:(p0 p1 p2 all)' \
'-e+[Target environment]:ENV:_default' \
'--env=[Target environment]:ENV:_default' \
'-p+[Cloud provider Terraform root]:PROVIDER:_default' \
'--provider=[Cloud provider Terraform root]:PROVIDER:_default' \
'--root=[Override the vpn-deploy repo root (default\: discover from cwd)]:ROOT:_files' \
'--explain[Print the underlying shell invocations and exit without running them]' \
