(( $+functions[_vpnd_commands] )) ||
_vpnd_commands() {
    local commands; commands=(
'deploy:Interactive deploy wizard' \
'reconverge:Idempotent re-deploy against existing host(s)' \
'share:Bundled recipient handoff (URL + QR + sing-box + app cards)' \
'doctor:Diagnostic bundle' \
'probe:Profile-aware probing' \
'preflight:Pre-deploy guards (spot-check, certs, perms, render, schema)' \
'fleet:Fleet-wide operations' \
'host:Local host registry' \
'ai-docs:Machine-readable docs endpoints for AI assistants' \
'update:Check for a newer vpnd release on GitHub (cached 24 h)' \
'completions:Emit shell completions to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vpnd commands' commands "$@"
}
(( $+functions[_vpnd__subcmd__ai-docs_commands] )) ||
_vpnd__subcmd__ai-docs_commands() {
    local commands; commands=()
    _describe -t commands 'vpnd ai-docs commands' commands "$@"
}
(( $+functions[_vpnd__subcmd__completions_commands] )) ||
_vpnd__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'vpnd completions commands' commands "$@"
}
(( $+functions[_vpnd__subcmd__deploy_commands] )) ||
_vpnd__subcmd__deploy_commands() {
