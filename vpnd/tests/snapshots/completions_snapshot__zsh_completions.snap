    local commands; commands=(
'status:Summary table across every host\:env pair' \
'rotate:Coordinated rotation across the fleet (\`scripts/fleet-rotate.sh\`)' \
'drift:Diff fleet state against the last known-good tag' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vpnd fleet commands' commands "$@"
}
