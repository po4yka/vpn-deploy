---
source: tests/completions_snapshot.rs
expression: output
---
_vpnd() {
    local i cur prev opts cmd
    COMPREPLY=()
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        cur="$2"
    else
        cur="${COMP_WORDS[COMP_CWORD]}"
    fi
    prev="$3"
    cmd=""
    opts=""

    for i in "${COMP_WORDS[@]:0:COMP_CWORD}"
    do
        case "${cmd},${i}" in
            ",$1")
                cmd="vpnd"
                ;;
            vpnd,ai-docs)
                cmd="vpnd__subcmd__ai__subcmd__docs"
                ;;
            vpnd,completions)
                cmd="vpnd__subcmd__completions"
                ;;
            vpnd,deploy)
                cmd="vpnd__subcmd__deploy"
                ;;
            vpnd,doctor)
                cmd="vpnd__subcmd__doctor"
                ;;
            vpnd,fleet)
                cmd="vpnd__subcmd__fleet"
                ;;
            vpnd,help)
                cmd="vpnd__subcmd__help"
                ;;
            vpnd,host)
                cmd="vpnd__subcmd__host"
                ;;
            vpnd,preflight)
