# Copy to staging.tfvars and fill. Do NOT commit staging.tfvars.

server_name = "vpn-staging-hel1"
location    = "hel1"
server_type = "cpx11"
image       = "debian-12"

admin_user           = "deploy"
admin_ssh_public_key = "ssh-ed25519 AAAA_STAGING_PUBLIC_KEY operator@laptop"

allowed_ssh_cidrs = ["203.0.113.42/32"]

enable_hysteria = true
build_env       = "staging"

labels = {
  project = "vpn-deploy"
  env     = "staging"
}
