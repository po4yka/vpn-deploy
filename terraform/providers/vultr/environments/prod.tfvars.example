# Copy to prod.tfvars and fill. Do NOT commit prod.tfvars.
# Export TF_VAR_vultr_api_key instead of placing the API key here.

server_name = "vpn-prod-ams1"
region      = "ams"
plan        = "vc2-1c-1gb"
os_id       = 1743 # replace with your pinned Debian/Ubuntu OS id

admin_user           = "deploy"
admin_ssh_public_key = "ssh-ed25519 AAAA_PROD_PUBLIC_KEY operator@laptop"

allowed_ssh_cidrs = [
  # Replace with your management IP. Never leave 0.0.0.0/0 for SSH.
  "203.0.113.42/32",
]

enable_hysteria = true
build_env       = "prod"

labels = {
  project = "vpn-deploy"
}
