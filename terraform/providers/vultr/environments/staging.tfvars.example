# Copy to staging.tfvars and fill. Do NOT commit staging.tfvars.
# Export TF_VAR_vultr_api_key instead of placing the API key here.

server_name = "vpn-staging-ams1"
region      = "ams"
plan        = "vc2-1c-2gb"
os_id       = 1743 # replace with your pinned Debian/Ubuntu OS id

admin_user           = "deploy"
admin_ssh_public_key = "ssh-ed25519 AAAA_STAGING_PUBLIC_KEY operator@laptop"

allowed_ssh_cidrs = ["203.0.113.42/32"]

enable_hysteria = true
build_env       = "staging"

labels = {
  project = "vpn-deploy"
  env     = "staging"
}
