# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform/providers/*/.terraform/
terraform/providers/*/*.tfstate
terraform/providers/*/*.tfstate.*
terraform/providers/*/*.tfplan
terraform/providers/*/environments/*.tfvars
!terraform/providers/*/environments/*.tfvars.example

# Ansible
ansible/inventory/generated.ini
*.retry
.ansible/
.ansible-cache/

# Secrets
secrets/*
!secrets/README.md
!secrets/.gitkeep
!secrets/prod.secrets.example.yaml
!secrets/.sops.yaml.example
.env
.envrc
*.key
*.pem
*.age

# Decrypted SOPS files
*.sops.yaml.dec
*.sops.json.dec

# Python
.venv/
venv/
__pycache__/
*.pyc

# Molecule
**/molecule/**/.molecule/
**/molecule/**/__pycache__/

# Operator-side artifacts (not for git)
state-backups/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# pre-commit
.pre-commit-cache/

# Claude Code local state
.claude/

# SBOM artifacts (reproducible from secrets schema via make emit-sbom)
sbom/*.json
