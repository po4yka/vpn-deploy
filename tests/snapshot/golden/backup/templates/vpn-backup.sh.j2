#!/usr/bin/env bash
# Managed by Ansible role `backup`. Runs once daily via vpn-backup.timer.
set -euo pipefail

REPO="/var/backups/vpn-restic"
export RESTIC_PASSWORD_FILE=/etc/restic/password

INCLUDES=(
  /etc/xray
  /etc/hysteria
  /etc/amnezia
  /etc/nginx
  /etc/nftables.conf
  /etc/ssh
  /etc/sysctl.d
  /etc/systemd/system
  /etc/vpn-watchdog.env
)

restic -r "$REPO" backup \
  --tag "vpn-stack" \
  --tag "host=$(hostname)" \
  "${INCLUDES[@]}"

restic -r "$REPO" forget \
  --tag vpn-stack \
  --keep-daily 7 --keep-weekly 4 --keep-monthly 6 \
  --prune


