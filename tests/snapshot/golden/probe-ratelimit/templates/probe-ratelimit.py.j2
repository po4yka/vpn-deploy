#!/usr/bin/env python3
"""Active-probing rate-limiter daemon.

Tails /var/log/xray/access.log. Each line that matches "REJECT" or
"graylist" carries a source IP — when the same IP exceeds
REJECTS_PER_WINDOW within WINDOW_SECONDS, the IP is added to the
nftables set `inet filter probe_offenders` with a BAN_SECONDS timeout.
nftables already has an early-drop rule for that set.

Why nftables instead of an Xray runtime API: Xray doesn't expose
graylist policy at runtime, so we can't tighten the response from the
proxy itself. Network-layer drop closes the door before the
ClientHello even arrives.

Managed by Ansible role probe-ratelimit; do not hand-edit.
"""
from __future__ import annotations

import collections
import logging
import pathlib
import re
import shlex
import subprocess
import sys
import time

XRAY_LOG = pathlib.Path("/var/log/xray/access.log")
REJECTS_PER_WINDOW = 5
WINDOW_SECONDS = 60
BAN_SECONDS = 300
TEXTFILE_DIR = pathlib.Path("/var/lib/node_exporter/textfile")

IP_RE = re.compile(r"\b(\d{1,3}(?:\.\d{1,3}){3})\b")
EVENT_RE = re.compile(r"(REJECT|rejected|graylist)", re.IGNORECASE)

logging.basicConfig(
    format="probe-ratelimit[%(process)d]: %(levelname)s %(message)s",
    level=logging.INFO, stream=sys.stderr,
)


def add_offender(ip: str) -> None:
    cmd = [
        "nft", "add", "element", "inet", "filter", "probe_offenders",
        "{", f"{ip} timeout {BAN_SECONDS}s", "}",
    ]
    rc = subprocess.run(cmd, capture_output=True).returncode
    if rc == 0:
        logging.info("banned %s for %ds", ip, BAN_SECONDS)
    else:
        logging.warning("nft add element failed for %s (rc=%d)", ip, rc)


def flush_textfile(bans: int, observed: int) -> None:
    try:
        TEXTFILE_DIR.mkdir(parents=True, exist_ok=True)
        out = TEXTFILE_DIR / "vpn_probe_ratelimit.prom"
        tmp = out.with_suffix(".prom.tmp")
        tmp.write_text(
            "# HELP vpn_probe_ratelimit_bans_total Total IPs banned since service start\n"
            "# TYPE vpn_probe_ratelimit_bans_total counter\n"
            f"vpn_probe_ratelimit_bans_total {bans}\n"
            "# HELP vpn_probe_ratelimit_events_total REJECT/graylist events tailed since service start\n"
            "# TYPE vpn_probe_ratelimit_events_total counter\n"
            f"vpn_probe_ratelimit_events_total {observed}\n"
        )
        tmp.replace(out)
    except OSError as exc:
        logging.debug("textfile flush skipped: %s", exc)


def tail(path: pathlib.Path):
    while not path.is_file():
        logging.info("waiting for %s to appear…", path)
        time.sleep(5)
    fh = path.open("r", errors="replace")
    fh.seek(0, 2)  # to EOF
    inode = path.stat().st_ino
    while True:
        line = fh.readline()
        if line:
            yield line
            continue
        time.sleep(0.5)
        try:
            new_inode = path.stat().st_ino
        except FileNotFoundError:
            continue
        if new_inode != inode:
            fh.close()
            fh = path.open("r", errors="replace")
            inode = new_inode


def main() -> None:
    history: dict[str, collections.deque[float]] = collections.defaultdict(
        lambda: collections.deque(maxlen=REJECTS_PER_WINDOW * 4))
    bans = 0
    observed = 0
    last_flush = 0.0
    for line in tail(XRAY_LOG):
        if not EVENT_RE.search(line):
            continue
        m = IP_RE.search(line)
        if not m:
            continue
        ip = m.group(1)
        # Drop RFC1918 etc. — we'd never ban an internal address.
        if ip.startswith(("10.", "127.", "192.168.")) or ip == "0.0.0.0":
            continue
        if ip.startswith("172."):
            second = int(ip.split(".", 2)[1])
            if 16 <= second <= 31:
                continue
        observed += 1
        now = time.time()
        dq = history[ip]
        dq.append(now)
        # Prune anything outside the window
        while dq and now - dq[0] > WINDOW_SECONDS:
            dq.popleft()
        if len(dq) >= REJECTS_PER_WINDOW:
            add_offender(ip)
            bans += 1
            dq.clear()  # avoid re-banning every event during a ban

        if now - last_flush > 15:
            flush_textfile(bans, observed)
            last_flush = now


if __name__ == "__main__":
    main()