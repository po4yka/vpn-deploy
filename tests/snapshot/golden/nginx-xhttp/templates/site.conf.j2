# Managed by Ansible role `nginx-xhttp`. Direct (no CDN) baseline.
# CDN-fronted variant lives in docs/CDN-DECISION.md as opt-in.


server {
    listen 8443 ssl http2;
    listen [::]:8443 ssl http2;

    server_name vpn.example.com;

    ssl_certificate     /etc/nginx/tls/vpn.example.com.fullchain.pem;
    ssl_certificate_key /etc/nginx/tls/vpn.example.com.key;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:vpn:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=31536000" always;

    # Realistic-looking healthcheck endpoint
    location = /health {
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    # XHTTP path → Xray localhost inbound
    location /app-sync/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP $remote_addr;

        # Streaming-friendly
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;

        proxy_pass http://127.0.0.1:10085;
    }

    # Plausible default site for unmatched paths
    location / {
        return 404;
    }

    access_log /var/log/nginx/vpn-xhttp.access.log;
    error_log  /var/log/nginx/vpn-xhttp.error.log warn;
}

# HTTP → HTTPS redirect (so the host looks like a normal website)
server {
    listen 80;
    listen [::]:80;
    server_name vpn.example.com;
    return 301 https://$host:8443$request_uri;
}
