[Unit]
Description=VPN active-probing honeypot listener
Documentation=https://github.com/po4yka/vpn-deploy/blob/main/ansible/roles/honeypot/defaults/main.yml
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=honeypot
Group=honeypot
ExecStart=/usr/local/bin/honeypot.py
Restart=on-failure
RestartSec=5s
LimitNOFILE=65536

# Hardening
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/log/honeypot /var/lib/node_exporter/textfile
ProtectControlGroups=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

[Install]
WantedBy=multi-user.target