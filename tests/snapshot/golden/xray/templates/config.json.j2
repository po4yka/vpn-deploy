
{
  "log": {
    "loglevel": "warning",
    "access": "{{ xray_log_dir | default('/var/log/xray') }}/access.log",
    "error": "{{ xray_log_dir | default('/var/log/xray') }}/error.log"
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "8.8.8.8",
      "https+local://dns.cloudflare.com/dns-query"
    ],
    "queryStrategy": "UseIP",
    "tag": "dns-inbound"
  },
  "inbounds": [
    {
      "tag": "vless-reality",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "REPLACE_WITH_UUID",
            "flow": "xtls-rprx-vision",
            "email": "phone"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "REPLACE_WITH_LOW_PROFILE_HTTPS_TARGET:443",
          "xver": 0,
          "serverNames": ["REPLACE_WITH_LOW_PROFILE_HOSTNAME"],
          "privateKey": "REPLACE_WITH_PRIVATE_KEY",
          "shortIds": [
            "REPLACE_WITH_8HEX"
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "metadataOnly": false,
        "routeOnly": false
      }
    },
    {
      "tag": "vless-xhttp-localhost",
      "listen": "127.0.0.1",
      "port": 10085,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "REPLACE_WITH_UUID",
            "email": "phone-xhttp"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "path": "/app-sync",
          "mode": "auto"
        },
        "sockopt": {
          "trustedXForwardedFor": ["127.0.0.1"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"],
        "metadataOnly": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      }
    },
    {
      "tag": "direct-asis",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "AsIs"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "none"
        }
      }
    },
    {
      "tag": "dns-out",
      "protocol": "dns"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "comment": "DNS hijack — keep client DNS lookups visible to xray and resolvable",
        "inboundTag": ["vless-reality","vless-xhttp-localhost"
        ],
        "port": "53",
        "outboundTag": "dns-out"
      },
      {
        "type": "field",
        "comment": "Probe-defense: block BitTorrent on the exit (graylist correlates BT)",
        "protocol": ["bittorrent"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "comment": "Probe-defense: refuse QUIC outbound to prevent UDP leak fingerprint",
        "network": "udp",
        "port": "443",
        "outboundTag": "block"
      },
      {
        "type": "field",
        "comment": "RFC1918 / link-local / loopback should never egress",
        "ip": [
          "geoip:private",
          "127.0.0.0/8",
          "169.254.0.0/16"
        ],
        "outboundTag": "block"
      },
      
      {
        "type": "field",
        "comment": "Default — direct freedom outbound with UseIP strategy",
        "outboundTag": "direct"
      }
    ]
  },
  "policy": {
    "levels": {
      "0": {
        "handshake": 4,
        "connIdle": 300,
        "uplinkOnly": 2,
        "downlinkOnly": 5,
        "bufferSize": 4
      }
    },
    "system": {
      "statsInboundUplink": false,
      "statsInboundDownlink": false
    }
  }
}