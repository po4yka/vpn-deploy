
[Interface]
PrivateKey = REPLACE_WITH_AWG_PRIVATE_KEY
Address    = 10.66.66.1/24, fd42:42:42::1/64
ListenPort = 51820

# AmneziaWG obfuscation parameters (mandatory; not standard WireGuard).
Jc = 4
Jmin = 40
Jmax = 70
S1 = 50
S2 = 100
H1 = REPLACE_WITH_H1_INT
H2 = REPLACE_WITH_H2_INT
H3 = REPLACE_WITH_H3_INT
H4 = REPLACE_WITH_H4_INT

# Outbound NAT for connected clients.
PostUp   = nft add rule inet nat postrouting iifname "%i" oifname != "%i" masquerade
PostDown = nft delete rule inet nat postrouting iifname "%i" oifname != "%i" masquerade


[Peer]
# phone
PublicKey  = REPLACE_WITH_PEER_PUBLIC_KEY
PresharedKey = REPLACE_WITH_PRESHARED_KEY
AllowedIPs = 10.66.66.2/32

