---
# ansible-lint configuration. Production profile is the default; we skip
# rules where our usage is intentional and well-tested:
#
# - name[casing]              molecule verify.yml uses lowercase task names
#                             for readability; this is test scaffolding, not
#                             production config.
# - command-instead-of-module  systemctl is sometimes the right tool — e.g.
#                             `systemctl is-active` for assertion (idempotent
#                             read-only check; the systemd module would emit
#                             changed=False but is heavier).
# - var-naming[no-role-prefix]  register vars in molecule scenarios are
#                             scoped to the test play and don't leak into
#                             the role's runtime variable namespace.
# - ignore-errors             used intentionally in handler `rescue:` blocks
#                             where the rescue is best-effort cleanup.
# - role-name                 nginx-xhttp and subscription-host are existing
#                             public role names referenced by CI, docs, and
#                             operator commands; renaming them is out of scope
#                             for lint config repair.

profile: production
supported_ansible_also:
  - "2.20."

skip_list:
  - name[casing]
  - command-instead-of-module
  - var-naming[no-role-prefix]
  - ignore-errors
  - role-name

exclude_paths:
  - .git/
  - .ansible/
  - .venv/
  - ansible/inventory/generated.ini
  - ansible/molecule/full-stack/test-secrets.yaml
  - molecule/full-stack/test-secrets.yaml
