{
  log default {
    output file {{ naive.log_dir }}/access.log
    level INFO
  }
  servers {
    protocols h1 h2 h3
  }
  auto_https off
}

:{{ naive.bind_port }}, {{ naive_secrets.server_name }} {
  tls {{ naive.config_dir }}/server.fullchain.pem {{ naive.config_dir }}/server.key

  route {
    forward_proxy {
      basic_auth {{ naive_secrets.username }} {{ naive_secrets.password }}
      hide_ip
      hide_via
      probe_resistance {{ naive_secrets.probe_resistance_secret }}
    }
    file_server {
      root {{ naive.decoy_root }}
    }
  }
}
