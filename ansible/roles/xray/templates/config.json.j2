{%- set _client_by_name = {} %}
{%- for _c in xray.clients %}{%- set _ = _client_by_name.update({_c.name: _c}) %}{%- endfor %}
{%- if (xray.cohorts | default([])) | length > 0 %}
  {%- set _cohorts = xray.cohorts %}
  {%- set _multi = true %}
{%- else %}
  {%- set _cohorts = [{
      "name": "default",
      "port": (xray_port | default(443)),
      "flow_mode": (vpn.xray_flow_mode | default('vision')),
      "finalmask": (vpn.xray_finalmask | default(false)),
      "clients": (xray.clients | map(attribute='name') | list),
  }] %}
  {%- set _multi = false %}
{%- endif %}
{
  "log": {
    "loglevel": "warning",
    "access": "{{ xray_log_path }}/access.log",
    "error": "{{ xray_log_path }}/error.log"
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "8.8.8.8",
      "https+local://dns.cloudflare.com/dns-query"
    ],
    "queryStrategy": "UseIP",
    "tag": "dns-inbound"
  },
  "inbounds": [
    {%- for _coh in _cohorts %}
    {%- set _coh_clients = _coh.clients | map('extract', _client_by_name) | list %}
    {
      "tag": "{% if _multi %}vless-reality-{{ _coh.name }}{% else %}vless-reality{% endif %}",
      "listen": "0.0.0.0",
      "port": {{ _coh.port }},
      "protocol": "vless",
      "settings": {
        "clients": [
          {%- for client in _coh_clients %}
          {
            "id": "{{ client.uuid }}",
            {%- if _coh.flow_mode == 'vision' %}
            "flow": "xtls-rprx-vision",
            {%- endif %}
            "email": "{{ client.name }}{% if _multi %}-{{ _coh.name }}{% endif %}"
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "{{ xray.target }}",
          "xver": 0,
          "serverNames": {{ xray.server_names | to_json }},
          "privateKey": "{{ xray.reality_private_key }}",
          "shortIds": [
            {%- for client in _coh_clients %}
            "{{ client.short_id }}"{% if not loop.last %},{% endif %}
            {%- endfor %}
          ]
        }{% if _coh.finalmask | default(false) %},
        "sockopt": {
          "finalmask": "Sudoku"
        }{% endif %}
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "metadataOnly": false,
        "routeOnly": false
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
    {%- if vpn.enable_nginx_xhttp | default(false) %},
    {
      "tag": "vless-xhttp-localhost",
      "listen": "127.0.0.1",
      "port": {{ nginx_xhttp_port | default(10085) }},
      "protocol": "vless",
      "settings": {
        "clients": [
          {%- for client in xray.clients %}
          {
            "id": "{{ client.uuid }}",
            "email": "{{ client.name }}-xhttp"
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "path": "{{ xray.xhttp_path | default('/app-sync') }}",
          "mode": "{{ xray.xhttp_mode | default('auto') }}"
        },
        "sockopt": {
          "trustedXForwardedFor": ["127.0.0.1"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"],
        "metadataOnly": false
      }
    }{% endif %}
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      }
    },
    {
      "tag": "direct-asis",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "AsIs"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "none"
        }
      }
    },
    {
      "tag": "dns-out",
      "protocol": "dns"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "comment": "DNS hijack — keep client DNS lookups visible to xray and resolvable",
        "inboundTag": [
          {%- for _coh in _cohorts -%}
          "{% if _multi %}vless-reality-{{ _coh.name }}{% else %}vless-reality{% endif %}"{% if not loop.last %},{% endif %}
          {%- endfor -%}
          {% if vpn.enable_nginx_xhttp | default(false) %},"vless-xhttp-localhost"{% endif %}
        ],
        "port": "53",
        "outboundTag": "dns-out"
      },
      {
        "type": "field",
        "comment": "Probe-defense: block BitTorrent on the exit (graylist correlates BT)",
        "protocol": ["bittorrent"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "comment": "Probe-defense: refuse QUIC outbound to prevent UDP leak fingerprint",
        "network": "udp",
        "port": "443",
        "outboundTag": "block"
      },
      {
        "type": "field",
        "comment": "RFC1918 / link-local / loopback should never egress",
        "ip": [
          "geoip:private",
          "127.0.0.0/8",
          "169.254.0.0/16"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "comment": "Default — direct freedom outbound with UseIP strategy",
        "outboundTag": "direct"
      }
    ]
  },
  "policy": {
    "levels": {
      "0": {
        "handshake": 4,
        "connIdle": 300,
        "uplinkOnly": 2,
        "downlinkOnly": 5,
        "bufferSize": 4
      }
    },
    "system": {
      "statsInboundUplink": false,
      "statsInboundDownlink": false
    }
  }
}