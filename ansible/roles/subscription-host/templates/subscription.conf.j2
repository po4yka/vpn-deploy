# Subscription delivery host. Listens on a non-default port to keep the
# transport endpoint and the delivery endpoint topologically separated.

server {
    listen {{ subscription.port | default(8444) }} ssl http2;
    listen [::]:{{ subscription.port | default(8444) }} ssl http2;

    server_name {{ subscription.server_name | default(nginx_xhttp.server_name) }};

    ssl_certificate     /etc/nginx/tls/{{ subscription.server_name | default(nginx_xhttp.server_name) }}.fullchain.pem;
    ssl_certificate_key /etc/nginx/tls/{{ subscription.server_name | default(nginx_xhttp.server_name) }}.key;

    ssl_protocols       TLSv1.2 TLSv1.3;
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header Cache-Control "no-store" always;
    add_header Referrer-Policy "no-referrer" always;

    # Token-keyed payload: /sub/<token>
    # Captures the token into $vpn_sub_token so the revocation map can read it.
    # Quote the regex: nginx parses bare `{16,64}` as a block opener.
    location ~ "^/sub/(?<vpn_sub_token>[A-Za-z0-9_-]{16,64})$" {
        # Short-circuit revoked tokens (map lives in conf.d/vpn-sub-revoked.conf)
        if ($vpn_sub_revoked = 1) {
            return 410;
        }

        # Rate-limit per source IP (zone defined in conf.d/vpn-sub-ratelimit.conf)
        limit_req zone=vpn_sub_per_ip burst={{ subscription.rate_burst | default(3) }} nodelay;
        limit_req_status 429;

        alias /var/lib/vpn-sub/$vpn_sub_token;
        default_type application/json;
        try_files $uri =404;

        # No access logging on the subscription host — privacy invariant.
        access_log off;
    }

{% if subscription.enable_bootstrap | default(false) %}
    # One-time bootstrap tokens (single-use, optional server-side
    # expiry via sidecar meta). Proxied to the local vpn-bootstrap
    # service which atomically deletes the payload after first
    # successful read. Rate-limited via the same zone as /sub/.
    location ~ "^/bootstrap/(?<vpn_boot_token>[A-Za-z0-9_-]{16,64})$" {
        limit_req zone=vpn_sub_per_ip burst={{ subscription.rate_burst | default(3) }} nodelay;
        limit_req_status 429;

        proxy_pass http://{{ subscription.bootstrap_listen_addr | default('127.0.0.1') }}:{{ subscription.bootstrap_listen_port | default(8445) }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        # Make Cache-Control / Referrer-Policy explicit at the location
        # level — nginx normally inherits the server-level `add_header`
        # directives, but a single location-level `add_header` resets
        # inheritance for that location, so we re-state both.
        add_header Cache-Control "no-store"   always;
        add_header Referrer-Policy "no-referrer" always;

        access_log off;
    }
{% endif %}

    # Reject everything else.
    location / {
        return 404;
    }

    error_log /var/log/nginx/vpn-sub.error.log warn;
}
