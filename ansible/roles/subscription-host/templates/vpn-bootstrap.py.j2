#!/usr/bin/env python3
"""One-time bootstrap token server. Listens on 127.0.0.1; nginx proxies
/bootstrap/<token> requests to us. We look up the token in
/var/lib/vpn-bootstrap/<token>, return its contents once, then delete
the file atomically. Subsequent requests for the same token get 410.

The server has no auth of its own — the bootstrap token IS the bearer.
Nginx is the only allowed peer; nginx does the rate-limit and TLS.

Managed by Ansible role subscription-host; do not hand-edit.
"""
from __future__ import annotations

import logging
import os
import pathlib
import re
import sys
import threading
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

BOOTSTRAP_DIR = pathlib.Path("{{ subscription.bootstrap_dir | default('/var/lib/vpn-bootstrap') }}")
TOKEN_RE = re.compile(r"^/bootstrap/([A-Za-z0-9_-]{16,64})$")
LISTEN_ADDR = "{{ subscription.bootstrap_listen_addr | default('127.0.0.1') }}"
LISTEN_PORT = {{ subscription.bootstrap_listen_port | default(8445) }}

_lock = threading.Lock()

logging.basicConfig(
    format="vpn-bootstrap[%(process)d]: %(levelname)s %(message)s",
    level=logging.INFO,
    stream=sys.stderr,
)


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):  # noqa: D401  -- silence default access log
        # We log only token outcomes (consumed / unknown / repeat),
        # never the URL path, to keep the access pattern out of disk
        # logs. Errors still go to systemd journal via stderr.
        return

    def do_GET(self):  # noqa: N802
        m = TOKEN_RE.match(self.path)
        if not m:
            self.send_error(404)
            return
        token = m.group(1)
        path = BOOTSTRAP_DIR / token
        meta_path = BOOTSTRAP_DIR / f"{token}.meta"
        with _lock:
            try:
                data = path.read_bytes()
            except FileNotFoundError:
                logging.info("token %s: unknown or already consumed", token[:8])
                self.send_error(410, "Gone")
                return
            # Optional per-token expiry. The sidecar carries either an ISO
            # date string or a unix-epoch integer; either is fine.
            if meta_path.is_file():
                try:
                    import json as _json
                    meta = _json.loads(meta_path.read_text())
                except (OSError, ValueError):
                    meta = {}
                expires = meta.get("expires")
                if expires is not None:
                    import datetime as _dt
                    now = _dt.datetime.now(tz=_dt.timezone.utc)
                    if isinstance(expires, (int, float)):
                        exp_dt = _dt.datetime.fromtimestamp(expires, tz=_dt.timezone.utc)
                    else:
                        try:
                            exp_dt = _dt.datetime.fromisoformat(str(expires)).replace(
                                tzinfo=_dt.timezone.utc)
                        except ValueError:
                            exp_dt = None
                    if exp_dt is not None and exp_dt < now:
                        logging.info("token %s: expired (%s)", token[:8], expires)
                        # Atomically remove both to prevent re-serving.
                        try: path.unlink()
                        except FileNotFoundError: pass
                        try: meta_path.unlink()
                        except FileNotFoundError: pass
                        self.send_error(410, "Gone")
                        return
            # Atomic consume: delete payload first, then meta (best-effort).
            path.unlink()
            if meta_path.is_file():
                try: meta_path.unlink()
                except FileNotFoundError: pass
        logging.info("token %s: consumed (%d bytes)", token[:8], len(data))
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-store")
        self.send_header("Referrer-Policy", "no-referrer")
        self.end_headers()
        self.wfile.write(data)


def main():
    BOOTSTRAP_DIR.mkdir(parents=True, exist_ok=True)
    server = ThreadingHTTPServer((LISTEN_ADDR, LISTEN_PORT), Handler)
    logging.info("listening on http://%s:%d/", LISTEN_ADDR, LISTEN_PORT)
    try:
        server.serve_forever()
    finally:
        server.server_close()


if __name__ == "__main__":
    main()