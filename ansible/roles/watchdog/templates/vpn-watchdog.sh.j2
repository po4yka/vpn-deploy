#!/usr/bin/env bash
# Probes each enabled transport. After FAIL_THRESHOLD consecutive failures,
# pushes an alert via ntfy.sh / Pushover, then continues. State (consecutive
# failures + alert times) is kept in $STATE_FILE.
set -euo pipefail

# Loaded by systemd EnvironmentFile=
: "${FAIL_THRESHOLD:=3}"
: "${STATE_FILE:=/var/lib/vpn-watchdog/state}"
: "${ALERTS_PER_HOUR_MAX:=4}"
: "${HOSTNAME:?HOSTNAME required}"

mkdir -p "$(dirname "$STATE_FILE")"

# State format (key=value, one per line):
#   consecutive_fails=<n>
#   last_alert_epoch=<unix>
#   alerts_this_hour=<n>
#   alerts_hour_started=<unix>
declare -A STATE
if [[ -f "$STATE_FILE" ]]; then
  while IFS='=' read -r k v; do
    [[ -n "$k" ]] && STATE["$k"]="$v"
  done < "$STATE_FILE"
fi
STATE[consecutive_fails]="${STATE[consecutive_fails]:-0}"
STATE[last_alert_epoch]="${STATE[last_alert_epoch]:-0}"
STATE[alerts_this_hour]="${STATE[alerts_this_hour]:-0}"
STATE[alerts_hour_started]="${STATE[alerts_hour_started]:-$(date +%s)}"

probe_results=()
probe_failures=()

probe() {
  local name="$1"; shift
  if "$@" >/dev/null 2>&1; then
    probe_results+=("OK    $name")
  else
    probe_results+=("FAIL  $name")
    probe_failures+=("$name")
  fi
}

if [[ "${ENABLE_XRAY:-true}" == "true" ]]; then
  probe "xray.service active"      systemctl is-active --quiet xray
  probe "xray TCP/${XRAY_PORT:-443} listening" \
    bash -c "ss -lnt | awk '{print \$4}' | grep -q ':${XRAY_PORT:-443}\$'"
  probe "xray config valid" \
    /usr/local/bin/xray run -test -config /etc/xray/config.json
fi

if [[ "${ENABLE_NGINX_XHTTP:-true}" == "true" ]]; then
  probe "nginx.service active"     systemctl is-active --quiet nginx
  probe "nginx -t"                 nginx -t
fi

if [[ "${ENABLE_HYSTERIA:-false}" == "true" ]]; then
  probe "hysteria-server active"   systemctl is-active --quiet hysteria-server
  probe "hysteria UDP/${HYSTERIA_PORT:-443} listening" \
    bash -c "ss -lnu | awk '{print \$4}' | grep -q ':${HYSTERIA_PORT:-443}\$'"
fi

if [[ "${ENABLE_AMNEZIAWG:-false}" == "true" ]]; then
  probe "AWG iface ${AWG_INTERFACE:-awg0} up" \
    awg show "${AWG_INTERFACE:-awg0}"
fi

# Always check load + disk, soft signals
probe "disk root <90%" \
  bash -c '[[ $(df --output=pcent / | tail -1 | tr -d " %") -lt 90 ]]'

now=$(date +%s)

if [[ ${#probe_failures[@]} -gt 0 ]]; then
  STATE[consecutive_fails]=$(( STATE[consecutive_fails] + 1 ))
else
  STATE[consecutive_fails]=0
fi

# Reset hourly alert counter if hour rolled over
if (( now - STATE[alerts_hour_started] >= 3600 )); then
  STATE[alerts_hour_started]=$now
  STATE[alerts_this_hour]=0
fi

should_alert=0
if (( STATE[consecutive_fails] >= FAIL_THRESHOLD )) \
   && (( STATE[alerts_this_hour] < ALERTS_PER_HOUR_MAX )); then
  should_alert=1
fi

result_text="$(printf '%s\n' "${probe_results[@]}")"

if (( should_alert )); then
  fail_list="$(printf '%s, ' "${probe_failures[@]}" | sed 's/, $//')"
  title="VPN[$HOSTNAME] failing: ${fail_list}"
  body="consecutive_fails=${STATE[consecutive_fails]}
${result_text}"

  case "${WATCHDOG_PROVIDER:-ntfy}" in
    ntfy)
      auth_args=()
      if [[ -n "${NTFY_TOKEN:-}" ]]; then
        auth_args=(-H "Authorization: Bearer ${NTFY_TOKEN}")
      fi
      curl -fsS -X POST \
        -H "Title: ${title}" \
        -H "Priority: high" \
        -H "Tags: warning,vpn,${HOSTNAME}" \
        "${auth_args[@]}" \
        --data "${body}" \
        "${NTFY_URL%/}/${NTFY_TOPIC}" >/dev/null || true
      ;;
    pushover)
      curl -fsS -X POST https://api.pushover.net/1/messages.json \
        -d token="${PUSHOVER_TOKEN}" \
        -d user="${PUSHOVER_USER}" \
        -d title="${title}" \
        -d message="${body}" \
        -d priority=1 >/dev/null || true
      ;;
  esac

  STATE[last_alert_epoch]=$now
  STATE[alerts_this_hour]=$(( STATE[alerts_this_hour] + 1 ))
fi

# Persist state
{
  for k in consecutive_fails last_alert_epoch alerts_this_hour alerts_hour_started; do
    echo "${k}=${STATE[$k]}"
  done
} > "$STATE_FILE"
chmod 0640 "$STATE_FILE"

# Always log to journal so `journalctl -u vpn-watchdog.service` shows status
echo "watchdog: consecutive_fails=${STATE[consecutive_fails]} alerts_this_hour=${STATE[alerts_this_hour]}"
printf '%s\n' "${probe_results[@]}"

# Exit 0 even on probe failures — the systemd timer runs us regardless and we
# don't want failed status to mask the alert flow.
exit 0
