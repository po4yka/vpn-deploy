#!/usr/sbin/nft -f
# Managed by Ansible role `firewall`. Hand edits will be overwritten.

flush ruleset
{% set ssh_cidrs = [allowed_ssh_cidrs] if allowed_ssh_cidrs is string else (allowed_ssh_cidrs | default([])) %}
{% set ssh_v4_cidrs = ssh_cidrs | select('match', '^(?!.*:).*') | list %}
{% set ssh_v6_cidrs = ssh_cidrs | select('match', '.*:.*') | list %}
{% set xray_tcp_port = xray_port | default(443) | int %}
{% set nginx_tcp_port = nginx_xhttp_public_port | default(8443) | int %}
{% set nginx_collides_with_xray = (vpn.enable_xray_reality | default(true)) and nginx_tcp_port == xray_tcp_port %}

table inet filter {
  chain input {
    type filter hook input priority 0;
    policy drop;

    iif "lo" accept
    ct state established,related accept
    ct state invalid drop

    ip protocol icmp accept
    ip6 nexthdr ipv6-icmp accept

{% if ssh_v4_cidrs %}
    tcp dport 22 ip saddr { {{ ssh_v4_cidrs | join(", ") }} } accept
{% endif %}
{% if ssh_v6_cidrs %}
    tcp dport 22 ip6 saddr { {{ ssh_v6_cidrs | join(", ") }} } accept
{% endif %}

{% if vpn.enable_xray_reality | default(true) %}
    # P0 — REALITY over TCP
    tcp dport {{ xray_tcp_port }} accept
{% endif %}

{% if (vpn.enable_nginx_xhttp | default(true)) and not nginx_collides_with_xray %}
    # P1 — nginx-xhttp public HTTPS listener
    tcp dport {{ nginx_tcp_port }} accept
{% endif %}

{% if vpn.enable_hysteria | default(false) %}
    # P2 — Hysteria2 UDP
    udp dport 443 accept
{% endif %}

{% if vpn.enable_amneziawg | default(false) %}
    # P2 — AmneziaWG (default UDP/51820; override via group_vars if needed)
    udp dport {{ amneziawg.listen_port | default(51820) }} accept
{% endif %}

    counter drop
  }

  chain forward {
    type filter hook forward priority 0;
{% if vpn.enable_amneziawg | default(false) %}
    policy accept;
    iifname "awg0" accept
    oifname "awg0" accept
{% else %}
    policy drop;
{% endif %}
  }

  chain output {
    type filter hook output priority 0;
    policy accept;
  }
}

{% if vpn.enable_amneziawg | default(false) %}
table inet nat {
  chain postrouting {
    type nat hook postrouting priority 100;
    iifname "awg0" oifname != "awg0" masquerade
  }
}
{% endif %}
