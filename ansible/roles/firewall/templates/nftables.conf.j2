#!/usr/sbin/nft -f
# Managed by Ansible role `firewall`. Hand edits will be overwritten.

flush ruleset
{% set ssh_cidrs = [allowed_ssh_cidrs] if allowed_ssh_cidrs is string else (allowed_ssh_cidrs | default([])) %}
{% set ssh_v4_cidrs = ssh_cidrs | select('match', '^(?!.*:).*') | list %}
{% set ssh_v6_cidrs = ssh_cidrs | select('match', '.*:.*') | list %}
{% set _xray_cohorts = (xray.cohorts | default([])) if xray is defined else [] %}
{% if _xray_cohorts | length > 0 %}
{%   set xray_tcp_ports = _xray_cohorts | map(attribute='port') | map('int') | list %}
{% else %}
{%   set xray_tcp_ports = [xray_port | default(443) | int] %}
{% endif %}
{% set nginx_tcp_port = nginx_xhttp_public_port | default(8443) | int %}
{% set nginx_collides_with_xray = (vpn.enable_xray_reality | default(true)) and (nginx_tcp_port in xray_tcp_ports) %}

table inet filter {
{% if vpn.enable_probe_ratelimit | default(false) %}
  # Offenders set populated by probe-ratelimit.service; per-element
  # timeout is set when the daemon adds an entry.
  set probe_offenders {
    type ipv4_addr
    flags timeout
  }
{% endif %}

  chain input {
    type filter hook input priority 0;
    policy drop;

    iif "lo" accept
    ct state established,related accept
    ct state invalid drop
{% if vpn.enable_probe_ratelimit | default(false) %}

    # Early drop for IPs the probe-ratelimit daemon has flagged
    ip saddr @probe_offenders drop
{% endif %}

    ip protocol icmp accept
    ip6 nexthdr ipv6-icmp accept

{% if ssh_v4_cidrs %}
    tcp dport 22 ip saddr { {{ ssh_v4_cidrs | join(", ") }} } accept
{% endif %}
{% if ssh_v6_cidrs %}
    tcp dport 22 ip6 saddr { {{ ssh_v6_cidrs | join(", ") }} } accept
{% endif %}

{% if vpn.enable_xray_reality | default(true) %}
    # P0 — REALITY over TCP{% if _xray_cohorts | length > 0 %} ({{ _xray_cohorts | length }} cohorts){% endif %}
{% for p in xray_tcp_ports %}
    tcp dport {{ p }} accept{% if _xray_cohorts | length > 0 %}  # cohort: {{ (_xray_cohorts | selectattr('port','equalto', p) | map(attribute='name') | first) }}{% endif %}

{% endfor %}
{% endif %}

{% if (vpn.enable_nginx_xhttp | default(true)) and not nginx_collides_with_xray %}
    # P1 — nginx-xhttp public HTTPS listener
    tcp dport {{ nginx_tcp_port }} accept
{% endif %}

{% if vpn.enable_hysteria | default(false) %}
    # P2 — Hysteria2 UDP
    udp dport {{ hysteria_port | default(443) }} accept
{% if hysteria_port_range | default('') %}
    # P2 — Hysteria2 port-hopping range
    udp dport {{ hysteria_port_range }} accept
{% endif %}
{% endif %}

{% if vpn.enable_amneziawg | default(false) %}
{% set _awg_inst = (amneziawg_secrets.instances | default([])) if amneziawg_secrets is defined else [] %}
{% if _awg_inst | length > 0 %}
    # P2 — AmneziaWG ({{ _awg_inst | length }} instances)
{% for inst in _awg_inst %}
    udp dport {{ inst.listen_port }} accept  # awg instance: {{ inst.name }}
{% endfor %}
{% else %}
    # P2 — AmneziaWG (default UDP/51820; override via group_vars if needed)
    udp dport {{ amneziawg.listen_port | default(51820) }} accept
{% endif %}
{% endif %}

{% if vpn.enable_honeypot | default(false) %}
    # Active-probing canary (logs probes; no real service behind it)
    tcp dport {{ honeypot.port | default(4443) }} accept
{% endif %}

    counter drop
  }

  chain forward {
    type filter hook forward priority 0;
{% if vpn.enable_amneziawg | default(false) %}
    policy accept;
    iifname "awg0" accept
    oifname "awg0" accept
{% else %}
    policy drop;
{% endif %}
  }

  chain output {
    type filter hook output priority 0;
    policy accept;
  }
}

{% if vpn.enable_amneziawg | default(false) %}
table inet nat {
  chain postrouting {
    type nat hook postrouting priority 100;
    iifname "awg0" oifname != "awg0" masquerade
  }
}
{% endif %}
