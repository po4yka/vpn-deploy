#!/usr/bin/env python3
"""Active-probing canary listener.

Accepts every TCP connection on the configured port, reads the first
up-to-512 bytes (which is the TLS ClientHello for HTTPS probes), then
closes. Logs:

  * one JSON line per connection to {{ honeypot.log_dir }}/connections.log
  * a Prometheus textfile under {{ honeypot.textfile_dir }} with rolling
    per-minute counters

The point isn't to be a "good" honeypot — it's to count probe events
and surface SNI / source-IP / timing distribution. A spike here often
precedes TSPU mass-probing the real REALITY port; the watchdog's
active_probing class detects it on the production side, this one
detects it on the canary port before pivot.

Managed by Ansible role honeypot; do not hand-edit.
"""
from __future__ import annotations

import json
import logging
import pathlib
import socket
import struct
import sys
import threading
import time
from collections import deque

LISTEN_PORT = {{ honeypot.port }}
LOG_DIR = pathlib.Path("{{ honeypot.log_dir }}")
TEXTFILE_DIR = pathlib.Path("{{ honeypot.textfile_dir }}")
EVENTS_PER_MINUTE_MAX = {{ honeypot.events_per_minute_max | default(1000) }}

logging.basicConfig(
    format="honeypot[%(process)d]: %(levelname)s %(message)s",
    level=logging.INFO, stream=sys.stderr,
)

LOG_DIR.mkdir(parents=True, exist_ok=True)
TEXTFILE_DIR.mkdir(parents=True, exist_ok=True)

_events_lock = threading.Lock()
_recent_minutes: deque[tuple[int, int]] = deque(maxlen=60)  # (minute_epoch, count)
_total_events = 0
_unique_ips: set[str] = set()
_unique_snis: set[str] = set()


def _extract_sni(buf: bytes) -> str | None:
    """Quick-and-dirty SNI parse. Returns None on anything malformed."""
    try:
        if len(buf) < 5 or buf[0] != 0x16:  # not a handshake record
            return None
        # Skip record header (5) + handshake type/len/version/random (4+2+32) + session id
        i = 5 + 4 + 2 + 32
        if i + 1 > len(buf): return None
        sid_len = buf[i]; i += 1 + sid_len
        if i + 2 > len(buf): return None
        cs_len = struct.unpack(">H", buf[i:i+2])[0]; i += 2 + cs_len
        if i + 1 > len(buf): return None
        cm_len = buf[i]; i += 1 + cm_len
        if i + 2 > len(buf): return None
        ext_total = struct.unpack(">H", buf[i:i+2])[0]; i += 2
        end = min(i + ext_total, len(buf))
        while i + 4 <= end:
            ext_type = struct.unpack(">H", buf[i:i+2])[0]
            ext_len = struct.unpack(">H", buf[i+2:i+4])[0]; i += 4
            if ext_type == 0:  # server_name
                if i + 5 > len(buf): return None
                name_len = struct.unpack(">H", buf[i+3:i+5])[0]
                return buf[i+5:i+5+name_len].decode("ascii", errors="replace")
            i += ext_len
    except Exception:
        return None
    return None


def _flush_textfile() -> None:
    """Write a fresh prom textfile reflecting the rolling counters."""
    with _events_lock:
        per_min = list(_recent_minutes)
        total = _total_events
        unique_ips = len(_unique_ips)
        unique_snis = len(_unique_snis)
    out = TEXTFILE_DIR / "vpn_honeypot.prom"
    tmp = out.with_suffix(".prom.tmp")
    last_minute_count = per_min[-1][1] if per_min else 0
    sixty_minute_count = sum(c for _, c in per_min)
    lines = [
        "# HELP vpn_honeypot_events_total Total probe events seen since service start",
        "# TYPE vpn_honeypot_events_total counter",
        f"vpn_honeypot_events_total {total}",
        "# HELP vpn_honeypot_events_last_minute Events in the most recent observed minute",
        "# TYPE vpn_honeypot_events_last_minute gauge",
        f"vpn_honeypot_events_last_minute {last_minute_count}",
        "# HELP vpn_honeypot_events_60min Events in the most recent 60 minutes",
        "# TYPE vpn_honeypot_events_60min gauge",
        f"vpn_honeypot_events_60min {sixty_minute_count}",
        "# HELP vpn_honeypot_unique_ips Cumulative unique source IPs seen",
        "# TYPE vpn_honeypot_unique_ips gauge",
        f"vpn_honeypot_unique_ips {unique_ips}",
        "# HELP vpn_honeypot_unique_snis Cumulative unique SNIs seen",
        "# TYPE vpn_honeypot_unique_snis gauge",
        f"vpn_honeypot_unique_snis {unique_snis}",
    ]
    tmp.write_text("\n".join(lines) + "\n")
    tmp.replace(out)


def _bump(source_ip: str, sni: str | None) -> bool:
    """Returns True if this event is below the per-minute cap, False to drop."""
    global _total_events
    now_min = int(time.time()) // 60
    with _events_lock:
        if not _recent_minutes or _recent_minutes[-1][0] != now_min:
            _recent_minutes.append((now_min, 0))
        cur_min_count = _recent_minutes[-1][1]
        if cur_min_count >= EVENTS_PER_MINUTE_MAX:
            return False
        _recent_minutes[-1] = (now_min, cur_min_count + 1)
        _total_events += 1
        _unique_ips.add(source_ip)
        if sni:
            _unique_snis.add(sni)
    return True


def _flush_loop() -> None:
    while True:
        time.sleep(15)
        try:
            _flush_textfile()
        except Exception as exc:
            logging.warning("textfile flush failed: %s", exc)


def _handle(conn: socket.socket, addr: tuple[str, int]) -> None:
    src_ip, src_port = addr[0], addr[1]
    conn.settimeout(3.0)
    buf = b""
    try:
        while len(buf) < 512:
            chunk = conn.recv(512 - len(buf))
            if not chunk: break
            buf += chunk
    except socket.timeout:
        pass
    except Exception as exc:
        logging.debug("recv error from %s: %s", src_ip, exc)
    finally:
        try: conn.close()
        except Exception: pass

    sni = _extract_sni(buf) if buf else None
    if not _bump(src_ip, sni):
        return  # dropped by per-minute cap

    event = {
        "ts": int(time.time()),
        "src_ip": src_ip,
        "src_port": src_port,
        "bytes": len(buf),
        "sni": sni,
        "first16_hex": buf[:16].hex() if buf else "",
    }
    with (LOG_DIR / "connections.log").open("a") as fh:
        fh.write(json.dumps(event) + "\n")


def main() -> None:
    threading.Thread(target=_flush_loop, daemon=True).start()
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind(("0.0.0.0", LISTEN_PORT))
    s.listen(128)
    logging.info("honeypot listening on 0.0.0.0:%d", LISTEN_PORT)
    while True:
        conn, addr = s.accept()
        threading.Thread(target=_handle, args=(conn, addr), daemon=True).start()


if __name__ == "__main__":
    main()